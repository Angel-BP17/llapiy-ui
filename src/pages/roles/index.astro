---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import RolesModule from "../../components/roles/RolesModule";
---

<DashboardLayout title="Roles">
  <header class="mb-6 rounded-2xl border border-border bg-gradient-to-r from-slate-900 to-violet-700 p-5 text-white shadow-sm flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs uppercase tracking-[0.24em] text-white/60">Configuración de acceso</p>
      <h1 class="mt-2 text-2xl font-semibold">Roles y permisos</h1>
      <p class="mt-1 text-sm text-white/75">Gestiona las capacidades y seguridad del sistema.</p>
    </div>
  </header>

  <RolesModule client:load />
</DashboardLayout>
