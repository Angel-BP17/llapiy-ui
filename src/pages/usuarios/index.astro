---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import UsersModule from "../../components/users/UsersModule";
---

<DashboardLayout title="Usuarios">
  <header class="mb-6 rounded-2xl border border-border bg-gradient-to-r from-slate-900 to-slate-700 p-5 text-white shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-white/60">Gestión organizacional</p>
        <h1 class="mt-2 text-2xl font-semibold">Administración de usuarios</h1>
        <p class="mt-1 text-sm text-white/75">Controla cuentas, roles y accesos del personal.</p>
      </div>
    </div>
  </header>

  <UsersModule client:load />
</DashboardLayout>
