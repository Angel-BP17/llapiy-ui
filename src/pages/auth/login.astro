---
import Layout from "../../layouts/Layout.astro";
import { LoginForm } from "../../components/auth/LoginForm";
---

<Layout>
  <main class="relative min-h-screen overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center blur-2xl"
      style="background-image: url('/background.jpg');"
    >
    </div>
    <div class="absolute inset-0 bg-slate-900/20"></div>

    <div
      class="relative mx-auto flex min-h-screen max-w-6xl items-center px-4 py-10"
    >
      <div
        class="relative w-full overflow-hidden rounded-3xl border border-blue-300/70 bg-white/90 shadow-2xl backdrop-blur"
      >
        <div class="grid gap-0 lg:grid-cols-2">
          <section
            class="flex items-center justify-center bg-blue-300 px-10 py-16 text-black"
          >
            <div class="max-w-sm text-center">
              <img
                src="/logo.png"
                alt="Llapiy"
                class="mx-auto mb-6 w-80 drop-shadow-lg"
                loading="lazy"
              />
              <h1 class="text-3xl font-semibold tracking-tight">
                Bienvenido a Llapiy
              </h1>
              <p class="mt-3 text-sm text-black/80">
                Accede a tu panel con tus credenciales autorizadas.
              </p>
              <div
                class="mt-8 rounded-2xl border border-white/10 bg-white/30 px-5 py-4"
              >
                <p class="text-xs uppercase tracking-[0.2em] text-black/80">
                  Plataforma segura
                </p>
                <p class="mt-2 text-sm text-black/80">
                  Gestión centralizada y auditoría en tiempo real.
                </p>
              </div>
            </div>
          </section>

          <section class="flex items-center justify-center px-8 py-14 sm:px-12">
            <div class="w-full max-w-md">
              <div class="mb-8">
                <h2 class="text-2xl font-semibold text-slate-900">
                  Iniciar sesión
                </h2>
                <p class="mt-2 text-sm text-slate-500">
                  Ingresa tu usuario y contraseña para continuar.
                </p>
              </div>

              <LoginForm client:load />

              <p class="mt-6 text-center text-xs text-slate-400">
                ¿Problemas para ingresar? Contacta al administrador.
              </p>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>
</Layout>
